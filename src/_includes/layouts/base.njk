<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ title }} | Yokal Sports</title>
  <meta name="description" content="{{ description or 'Yokal Sports market coverage, rankings and local sports intelligence.' }}">
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="apple-touch-icon" href="/apple-touch-icon.png">
  <link rel="stylesheet" href="/assets/site.css">
  <script data-memberstack-app="app_cmpzrc8r1000f0tvo9wcd3h0r" src="https://static.memberstack.com/scripts/v2/memberstack.js" type="text/javascript"></script>
  {% if gated %}
  <style>body{visibility:hidden}</style>
  {% endif %}
</head>
<body>
{% set marketSlug = page.url.split('/')[1] or 'north-jersey' %}
{% set marketLabel = 'South Jersey' if marketSlug == 'south-jersey' else (market.market or 'North Jersey') %}
<header class="site-header">
  <div class="wrap masthead">
    <a class="logo" href="/"><img src="/Best_Yokal_Logo_6_16.jpg" alt="Yokal Sports"></a>
    <div class="market-name">{{ marketLabel }}</div>
  </div>
  <nav class="nav wrap" aria-label="Market navigation">
    <a href="/{{ marketSlug }}/">Free Preview</a>
    <a href="/{{ marketSlug }}/yokal/">Yokal Hub</a>
    <a href="/{{ marketSlug }}/yokal/boys/">Boys</a>
    <a href="/{{ marketSlug }}/yokal/girls/">Girls</a>
    <a href="/{{ marketSlug }}/yokal/college/">College</a>
    <a class="nav-action" href="#" data-ms-modal="login">Log In</a>
    <a class="nav-action" href="#" data-ms-modal="profile">Account</a>
  </nav>
</header>
<main>{{ content | safe }}</main>
<footer class="site-footer"><div class="wrap">Yokal Sports · yokals@yokalsports.com</div></footer>
{% if gated %}
<script>
(function() {
  var VALID_PLANS = ['pln_yokal-north-jersey-monthly--n3j0ou0', 'pln_yokal-north-jersey-annual--d5m0o3n'];
  function showPaywall() {
    document.body.innerHTML = '<div class="wrap" style="padding:80px 24px;text-align:center;">' +
      '<h1>This content is for Yokals</h1>' +
      '<p>Become a Yokal to unlock full North Jersey rankings, stats and data.</p>' +
      '<a class="btn primary-yokal" href="#" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Become a Yokal — $4.99/mo</a>' +
      '</div>';
    document.body.style.visibility = 'visible';
    if (window.$memberstackDom) window.$memberstackDom.openModal('signup');
  }
  window.$memberstackDom.getCurrentMember().then(function(res) {
    var member = res && res.data;
    if (!member) { showPaywall(); return; }
    var plans = (member.planConnections || []).map(function(p){ return p.planId; });
    var hasAccess = plans.some(function(id){ return VALID_PLANS.indexOf(id) !== -1; });
    if (!hasAccess) { showPaywall(); return; }
    document.body.style.visibility = 'visible';
  }).catch(function() { showPaywall(); });
})();
</script>
{% endif %}
</body>
</html>
