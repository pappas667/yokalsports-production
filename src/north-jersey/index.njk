  <div class="wrap" style="display:flex;align-items:center;justify-content:center;gap:10px;">
    <span style="font-family:Arial,sans-serif;font-size:11px;font-weight:900;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:0.08em;">Presented by</span>
    <span style="font-family:Arial,sans-serif;font-size:12px;font-weight:900;color:var(--lime);">Performance Kia of Denville</span>
    <span style="font-family:Arial,sans-serif;font-size:11px;color:rgba(255,255,255,0.5);">· Your North Jersey Sports Partner</span>
  </div>
</div>

<!-- HERO -->
<section class="section">
  <div class="wrap">
    <div class="section-head">
      <div>
        <h1>North Jersey</h1>
        <p>{{ market.counties | join(' · ') }}</p>
