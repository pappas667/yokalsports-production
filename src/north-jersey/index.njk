        <p>Rankings, school sports stories, local athletes and the market updates that matter.</p>
      </div>
      <div style="min-width:320px;flex:1;">
        <iframe src="https://embeds.beehiiv.com/037c3aba-6dae-4af3-980e-dfae9b170e62"
          width="100%" height="52" frameborder="0" scrolling="no"
          style="border-radius:8px;border:0;background:transparent;display:block;">
        </iframe>
      </div>
    </div>

    <!-- PREVIOUS YSSR ISSUES -->
    <div class="issues">
      <a class="issue-card" href="https://newsletter.yokalsports.com/p/the-yokal-sports-sports-report-north-jersey-32fd15c4d24a3a1b" target="_blank" rel="noopener">
        <div class="date">June 9, 2026</div>
        <h3>State Playoffs Are in Full Mode — Top Stories You Need to Know</h3>
      </a>
      <a class="issue-card" href="https://newsletter.yokalsports.com/p/the-yokal-sports-sports-report-north-jersey-9bc3d0f08b3ba4cb" target="_blank" rel="noopener">
        <div class="date">May 26, 2026</div>
        <h3>15 North Jersey Schools That Deserve Some Love This Spring</h3>
      </a>
      <a class="issue-card" href="https://newsletter.yokalsports.com/p/the-yokal-sports-sports-report-north-jersey-aa7940a04e688577" target="_blank" rel="noopener">
        <div class="date">May 19, 2026</div>
        <h3>Mount Olive Stuns Delbarton + County Finals &amp; College Corner</h3>
      </a>
      <a class="issue-card" href="https://newsletter.yokalsports.com/p/the-yokal-sports-sports-report-north-jersey-0d92e15c130f952d" target="_blank" rel="noopener">
        <div class="date">May 12, 2026</div>
        <h3>Don Bosco Wins 6th Straight Bergen County Lacrosse Title + Rankings</h3>
      </a>
    </div>

  </div>
</section>

<!-- 6 TEASER BOXES -->
{% if publication %}
<section class="section">
  <div class="wrap">

    <div class="section-head">
      <div>
        <h2>North Jersey Rankings</h2>
        <p>Updated {{ publication.publish_date | displayDate }} · Want the full list? Become a Yokal.</p>
      </div>
    </div>

    {% set boys_baseball = null %}
    {% set boys_lax = null %}
    {% set girls_softball = null %}
    {% set girls_lax = null %}
    {% for sport in publication.high_school.boys.sports %}
      {% if sport.name == "Baseball" %}{% set boys_baseball = sport %}{% endif %}
      {% if sport.name == "Boys Lacrosse" %}{% set boys_lax = sport %}{% endif %}
    {% endfor %}
    {% for sport in publication.high_school.girls.sports %}
      {% if sport.name == "Softball" %}{% set girls_softball = sport %}{% endif %}
      {% if sport.name == "Girls Lacrosse" %}{% set girls_lax = sport %}{% endif %}
    {% endfor %}

    <div class="two-col">

      <!-- BOX 1: Boys Teams -->
      <div class="data-card">
        <div class="card-head">
          <h3>⚾ Boys Teams — Top 50</h3>
          <div class="date-line">Baseball · Boys Lacrosse · {{ publication.publish_date | displayDate }}</div>
        </div>
        <div class="table-wrap"><table>
          <thead><tr><th>#</th><th>School</th><th>Sport</th><th>Score</th></tr></thead>
          <tbody>
            {% if boys_baseball %}{% for team in boys_baseball.teams | preview(5,10) %}
            <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong><br><small class="muted">{{ team.county }}</small></td><td>{{ team.sport }}</td><td>{{ team.score }}</td></tr>
            {% endfor %}{% endif %}
            {% if boys_lax %}{% for team in boys_lax.teams | preview(3,5) %}
            <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong><br><small class="muted">{{ team.county }}</small></td><td>{{ team.sport }}</td><td>{{ team.score }}</td></tr>
            {% endfor %}{% endif %}
          </tbody>
        </table></div>
        <a class="complete-list" href="#become" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
        <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Boys Teams">Sponsor This List →</a>
      </div>

      <!-- BOX 2: Girls Teams -->
      <div class="data-card">
        <div class="card-head">
          <h3>🥎 Girls Teams — Top 50</h3>
          <div class="date-line">Softball · Girls Lacrosse · {{ publication.publish_date | displayDate }}</div>
        </div>
        <div class="table-wrap"><table>
          <thead><tr><th>#</th><th>School</th><th>Sport</th><th>Score</th></tr></thead>
          <tbody>
            {% if girls_softball %}{% for team in girls_softball.teams | preview(5,10) %}
            <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong><br><small class="muted">{{ team.county }}</small></td><td>{{ team.sport }}</td><td>{{ team.score }}</td></tr>
            {% endfor %}{% endif %}
            {% if girls_lax %}{% for team in girls_lax.teams | preview(3,5) %}
            <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong><br><small class="muted">{{ team.county }}</small></td><td>{{ team.sport }}</td><td>{{ team.score }}</td></tr>
            {% endfor %}{% endif %}
          </tbody>
        </table></div>
        <a class="complete-list" href="#become" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
        <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Girls Teams">Sponsor This List →</a>
      </div>

      <!-- BOX 3: Boys Athletes -->
      <div class="data-card">
        <div class="card-head">
          <h3>🏅 Boys Athletes — Top 30</h3>
          <div class="date-line">Baseball · Boys Lacrosse · {{ publication.publish_date | displayDate }}</div>
        </div>
        <div class="table-wrap"><table>
          <thead><tr><th>#</th><th>Athlete</th><th>Sport</th><th>Score</th></tr></thead>
          <tbody>
            {% if boys_baseball %}{% for a in boys_baseball.athletes | preview(5,7) %}
            <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong><br><small class="muted">{{ a.school }}</small></td><td>{{ a.sport }}</td><td>{{ a.score }}</td></tr>
            {% endfor %}{% endif %}
            {% if boys_lax %}{% for a in boys_lax.athletes | preview(2,3) %}
            <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong><br><small class="muted">{{ a.school }}</small></td><td>{{ a.sport }}</td><td>{{ a.score }}</td></tr>
            {% endfor %}{% endif %}
          </tbody>
        </table></div>
        <a class="complete-list" href="#become" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
        <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Boys Athletes">Sponsor This List →</a>
      </div>

      <!-- BOX 4: Girls Athletes -->
      <div class="data-card">
        <div class="card-head">
          <h3>🏅 Girls Athletes — Top 30</h3>
          <div class="date-line">Softball · Girls Lacrosse · {{ publication.publish_date | displayDate }}</div>
        </div>
        <div class="table-wrap"><table>
          <thead><tr><th>#</th><th>Athlete</th><th>Sport</th><th>Score</th></tr></thead>
          <tbody>
            {% if girls_softball %}{% for a in girls_softball.athletes | preview(5,7) %}
            <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong><br><small class="muted">{{ a.school }}</small></td><td>{{ a.sport }}</td><td>{{ a.score }}</td></tr>
            {% endfor %}{% endif %}
            {% if girls_lax %}{% for a in girls_lax.athletes | preview(2,3) %}
            <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong><br><small class="muted">{{ a.school }}</small></td><td>{{ a.sport }}</td><td>{{ a.score }}</td></tr>
            {% endfor %}{% endif %}
          </tbody>
        </table></div>
        <a class="complete-list" href="#become" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
        <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Girls Athletes">Sponsor This List →</a>
      </div>

      <!-- BOX 5: Historical Win % -->
      <div class="data-card">
        <div class="card-head">
          <h3>📊 Historical Win %</h3>
          <div class="date-line">All Programs · {{ publication.publish_date | displayDate }}</div>
        </div>
        <div class="table-wrap"><table>
          <thead><tr><th>#</th><th>Program</th><th>Sport</th><th>Win%</th></tr></thead>
          <tbody>
            {% for prog in publication.historical_winpct | preview(5,15) %}
            <tr><td class="rank">{{ loop.index + 5 }}</td><td><strong>{{ prog.school }}</strong><br><small class="muted">{{ prog.level }}</small></td><td>{{ prog.sport }}</td><td>{{ prog.win_pct }}%</td></tr>
            {% endfor %}
          </tbody>
        </table></div>
        <a class="complete-list" href="#become" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
        <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Historical Win Pct">Sponsor This List →</a>
      </div>

      <!-- BOX 6: NIL Tracking -->
      <div class="data-card">
        <div class="card-head">
          <h3>💰 NIL Tracking</h3>
          <div class="date-line">HS + College Athletes · {{ publication.publish_date | displayDate }}</div>
        </div>
        <div class="table-wrap"><table>
          <thead><tr><th>Athlete</th><th>School</th><th>Sport</th><th>Status</th></tr></thead>
          <tbody>
            {% if publication.nil_tracking.length %}
              {% for nil in publication.nil_tracking | take(5) %}
              <tr><td><strong>{{ nil.player }}</strong></td><td>{{ nil.school }}</td><td>{{ nil.sport }}</td><td>{{ nil.commit or "Tracking" }}</td></tr>
              {% endfor %}
            {% else %}
            <tr><td colspan="4" class="empty">NIL data building. <a href="mailto:yokals@yokalsports.com">Submit a tip →</a></td></tr>
            {% endif %}
          </tbody>
        </table></div>
        <a class="complete-list" href="#become" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
        <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — NIL Tracking">Sponsor This List →</a>
      </div>

    </div>
  </div>
</section>
{% endif %}

