        <div class="date">May 26, 2026</div>
        <h3>15 North Jersey Schools That Deserve Some Love This Spring</h3>
      </a>
      <a class="issue-card" href="https://newsletter.yokalsports.com/p/the-yokal-sports-sports-report-north-jersey-aa7940a04e688577" target="_blank" rel="noopener">
        <div class="date">May 19, 2026</div>
        <h3>Mount Olive Stuns Delbarton + County Finals &amp; College Corner</h3>
      </a>
      <a class="issue-card" href="https://newsletter.yokalsports.com/p/the-yokal-sports-sports-report-north-jersey-0d92e15c130f952d" target="_blank" rel="noopener">
        <div class="date">May 12, 2026</div>
        <h3>Don Bosco Wins 6th Straight Bergen County Lacrosse Title + Rankings</h3>
      </a>
    </div>
  </div>
</section>

{% if publication %}

{% set boys_baseball = null %}
{% set boys_lax = null %}
{% set girls_softball = null %}
{% set girls_lax = null %}
{% for sport in publication.high_school.boys.sports %}
  {% if sport.name == "Baseball" %}{% set boys_baseball = sport %}{% endif %}
  {% if sport.name == "Boys Lacrosse" %}{% set boys_lax = sport %}{% endif %}
{% endfor %}
{% for sport in publication.high_school.girls.sports %}
  {% if sport.name == "Softball" %}{% set girls_softball = sport %}{% endif %}
  {% if sport.name == "Girls Lacrosse" %}{% set girls_lax = sport %}{% endif %}
{% endfor %}

<!-- HIGH SCHOOL -->
<section class="section">
  <div class="wrap">
    <div class="section-label">High School</div>
    <p class="section-sub">Updated {{ publication.publish_date | displayDate }} · Full lists available to Yokals</p>
    <div class="two-col">

      <!-- LEFT: BOYS -->
      <div class="col-stack">

        {% if boys_baseball %}
        <div class="data-card">
          <div class="card-head"><h3>Boys Baseball</h3><div class="date-line">{{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>School</th><th>County</th><th>YSSR Score</th></tr></thead>
            <tbody>
              {% for team in boys_baseball.teams %}{% if team.rank >= 6 and team.rank <= 15 %}
              <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong></td><td class="muted-cell">{{ team.county }}</td><td class="yssr-score">{{ team.score }}</td></tr>
              {% endif %}{% endfor %}
            </tbody>
          </table></div>
          <a class="complete-list" href="#" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
          <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Boys Baseball">Sponsor This List →</a>
        </div>
        {% endif %}

        {% if boys_lax %}
        <div class="data-card">
          <div class="card-head"><h3>Boys Lacrosse</h3><div class="date-line">{{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>School</th><th>County</th><th>YSSR Score</th></tr></thead>
            <tbody>
              {% for team in boys_lax.teams %}{% if team.rank >= 6 and team.rank <= 10 %}
              <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong></td><td class="muted-cell">{{ team.county }}</td><td class="yssr-score">{{ team.score }}</td></tr>
              {% endif %}{% endfor %}
            </tbody>
          </table></div>
          <a class="complete-list" href="#" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
          <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Boys Lacrosse">Sponsor This List →</a>
        </div>
        {% endif %}

        <div class="data-card">
          <div class="card-head"><h3>Boys Track &amp; Field</h3><div class="date-line">Data building</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>Athlete</th><th>School</th><th>YSSR Score</th></tr></thead>
            <tbody><tr><td colspan="4" class="empty">YSSR Score Building — submit results to <a href="mailto:yokals@yokalsports.com">yokals@yokalsports.com</a></td></tr></tbody>
          </table></div>
          <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Boys Track">Sponsor This List →</a>
        </div>

        {% if boys_baseball or boys_lax %}
        <div class="data-card">
          <div class="card-head"><h3>Boys Athletes</h3><div class="date-line">{{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>Athlete</th><th>School</th><th>YSSR Score</th></tr></thead>
            <tbody>
              {% if boys_baseball %}{% for a in boys_baseball.athletes %}{% if a.rank >= 6 and a.rank <= 10 %}
              <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong></td><td class="muted-cell">{{ a.school }}</td><td class="yssr-score">{{ a.score }}</td></tr>
              {% endif %}{% endfor %}{% endif %}
              {% if boys_lax %}{% for a in boys_lax.athletes %}{% if a.rank >= 3 and a.rank <= 5 %}
              <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong></td><td class="muted-cell">{{ a.school }}</td><td class="yssr-score">{{ a.score }}</td></tr>
              {% endif %}{% endfor %}{% endif %}
            </tbody>
          </table></div>
          <a class="complete-list" href="#" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
          <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Boys Athletes">Sponsor This List →</a>
        </div>
        {% endif %}

      </div>

      <!-- RIGHT: GIRLS -->
      <div class="col-stack">

        {% if girls_softball %}
        <div class="data-card">
          <div class="card-head"><h3>Girls Softball</h3><div class="date-line">{{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>School</th><th>County</th><th>YSSR Score</th></tr></thead>
            <tbody>
              {% for team in girls_softball.teams %}{% if team.rank >= 6 and team.rank <= 15 %}
              <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong></td><td class="muted-cell">{{ team.county }}</td><td class="yssr-score">{{ team.score }}</td></tr>
              {% endif %}{% endfor %}
            </tbody>
          </table></div>
          <a class="complete-list" href="#" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
          <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Girls Softball">Sponsor This List →</a>
        </div>
        {% endif %}

        {% if girls_lax %}
        <div class="data-card">
          <div class="card-head"><h3>Girls Lacrosse</h3><div class="date-line">{{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>School</th><th>County</th><th>YSSR Score</th></tr></thead>
            <tbody>
              {% for team in girls_lax.teams %}{% if team.rank >= 6 and team.rank <= 10 %}
              <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong></td><td class="muted-cell">{{ team.county }}</td><td class="yssr-score">{{ team.score }}</td></tr>
              {% endif %}{% endfor %}
            </tbody>
          </table></div>
          <a class="complete-list" href="#" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
          <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Girls Lacrosse">Sponsor This List →</a>
        </div>
        {% endif %}

        <div class="data-card">
          <div class="card-head"><h3>Girls Track &amp; Field</h3><div class="date-line">Data building</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>Athlete</th><th>School</th><th>YSSR Score</th></tr></thead>
            <tbody><tr><td colspan="4" class="empty">YSSR Score Building — submit results to <a href="mailto:yokals@yokalsports.com">yokals@yokalsports.com</a></td></tr></tbody>
          </table></div>
          <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Girls Track">Sponsor This List →</a>
        </div>

        {% if girls_softball or girls_lax %}
        <div class="data-card">
          <div class="card-head"><h3>Girls Athletes</h3><div class="date-line">{{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>Athlete</th><th>School</th><th>YSSR Score</th></tr></thead>
            <tbody>
              {% if girls_softball %}{% for a in girls_softball.athletes %}{% if a.rank and a.score and a.rank >= 6 and a.rank <= 10 %}
              <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong></td><td class="muted-cell">{{ a.school }}</td><td class="yssr-score">{{ a.score }}</td></tr>
              {% endif %}{% endfor %}{% endif %}
              {% if girls_lax %}{% for a in girls_lax.athletes %}{% if a.rank and a.score and a.rank >= 3 and a.rank <= 5 %}
              <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong></td><td class="muted-cell">{{ a.school }}</td><td class="yssr-score">{{ a.score }}</td></tr>
              {% endif %}{% endfor %}{% endif %}
            </tbody>
          </table></div>
          <a class="complete-list" href="#" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
          <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — Girls Athletes">Sponsor This List →</a>
        </div>
        {% endif %}

      </div>

      <!-- HS WIN % -->
      <div class="data-card">
        <div class="card-head"><h3>Historical Win %</h3><div class="date-line">All HS Programs · {{ publication.publish_date | displayDate }}</div></div>
        <div class="table-wrap"><table>
          <thead><tr><th>#</th><th>Program</th><th>Sport</th><th>Win%</th></tr></thead>
          <tbody>
            {% set hscount = 0 %}
            {% for prog in publication.historical_winpct %}
              {% if prog.win_pct and prog.level != "College" %}
                {% set hscount = hscount + 1 %}
                {% if hscount >= 6 and hscount <= 20 %}
                <tr><td class="rank">{{ hscount }}</td><td><strong>{{ prog.school }}</strong></td><td class="muted-cell">{{ prog.sport }}{% if prog.gender %} · {{ prog.gender }}{% endif %}</td><td class="yssr-score-plain">{{ prog.win_pct }}%</td></tr>
                {% endif %}
              {% endif %}
            {% endfor %}
            {% if hscount < 6 %}<tr><td colspan="4" class="empty">Win% data building</td></tr>{% endif %}
          </tbody>
        </table></div>
        <a class="complete-list" href="#" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
        <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — HS Win Pct">Sponsor This List →</a>
      </div>

      <!-- HS NIL -->
      <div class="data-card">
        <div class="card-head"><h3>NIL Tracking</h3><div class="date-line">HS Athletes · {{ publication.publish_date | displayDate }}</div></div>
        <div class="table-wrap"><table>
          <thead><tr><th>Athlete</th><th>School</th><th>Sport</th><th>Status</th></tr></thead>
          <tbody>
            {% if publication.nil_tracking and publication.nil_tracking.length %}
              {% for nil in publication.nil_tracking | take(10) %}
              <tr><td><strong>{{ nil.player }}</strong></td><td class="muted-cell">{{ nil.school }}</td><td class="muted-cell">{{ nil.sport }}</td><td>{{ nil.commit or "Tracking" }}</td></tr>
              {% endfor %}
            {% else %}
            <tr><td colspan="4" class="empty">NIL data building — <a href="mailto:yokals@yokalsports.com">Submit a tip →</a></td></tr>
            {% endif %}
          </tbody>
        </table></div>
        <a class="complete-list" href="#" data-ms-modal="signup" data-ms-price:add="prc_yokal-nj-monthly-x3470asv">Want the complete list? Become a Yokal →</a>
        <a class="sponsor-slot" href="mailto:yokals@yokalsports.com?subject=Sponsor This List — NIL Tracking">Sponsor This List →</a>
      </div>

    </div>
  </div>
</section>

<!-- COLLEGE CORNER -->
