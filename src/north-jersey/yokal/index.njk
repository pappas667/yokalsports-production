---
layout: layouts/base.njk
title: North Jersey Yokal Hub
permalink: /north-jersey/yokal/index.html
ms_content: prc_yokal-nj-monthly-x3470asv,prc_yokal-nj-annual-374v08rm
---

{% set publication = market.latestPublication %}

<section class="section">
  <div class="wrap">

    <div class="section-head">
      <div>
        <h1>North Jersey Yokal Hub</h1>
        <p>{% if publication %}Updated {{ publication.publish_date | displayDate }}{% endif %} · Full data · All 11 counties</p>
      </div>
    </div>

    {% if publication %}

    {% set boys_baseball = null %}
    {% set boys_lax = null %}
    {% set girls_softball = null %}
    {% set girls_lax = null %}
    {% for sport in publication.high_school.boys.sports %}
      {% if sport.name == "Baseball" %}{% set boys_baseball = sport %}{% endif %}
      {% if sport.name == "Boys Lacrosse" %}{% set boys_lax = sport %}{% endif %}
    {% endfor %}
    {% for sport in publication.high_school.girls.sports %}
      {% if sport.name == "Softball" %}{% set girls_softball = sport %}{% endif %}
      {% if sport.name == "Girls Lacrosse" %}{% set girls_lax = sport %}{% endif %}
    {% endfor %}

    <!-- HIGH SCHOOL BOYS + GIRLS — two columns -->
    <h2 style="color:var(--navy);font-family:Georgia,serif;margin:0 0 12px;letter-spacing:-.03em;">High School Boys &amp; Girls Rankings</h2>
    <div class="two-col" style="margin-bottom:24px;">

      <!-- BOYS LEFT -->
      <div class="stack">
        <div class="eyebrow" style="margin-bottom:6px;">High School Boys</div>

        {% if boys_baseball %}
        <!-- Baseball Teams -->
        <div class="data-card">
          <div class="card-head"><h3>Baseball — Top {{ boys_baseball.teams | length }} Teams</h3><div class="date-line">Baseball · {{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>School</th><th>County</th><th>Record</th><th>Score</th></tr></thead>
            <tbody>
              {% for team in boys_baseball.teams %}
              <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong></td><td>{{ team.county }}</td><td>{{ team.record }}</td><td>{{ team.score }}</td></tr>
              {% endfor %}
            </tbody>
          </table></div>
        </div>

        <!-- Baseball Athletes -->
        <div class="data-card">
          <div class="card-head"><h3>Baseball — Top {{ boys_baseball.athletes | length }} Players</h3><div class="date-line">Baseball · {{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>Player</th><th>School</th><th>Sport</th><th>Commit</th><th>Stats</th><th>Score</th></tr></thead>
            <tbody>
              {% for a in boys_baseball.athletes %}
              <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong></td><td>{{ a.school }}</td><td>{{ a.sport }}</td><td>{{ a.commit or "—" }}</td><td>{{ a.stats }}</td><td>{{ a.score }}</td></tr>
              {% endfor %}
            </tbody>
          </table></div>
        </div>
        {% endif %}

        {% if boys_lax %}
        <!-- Boys Lax Teams -->
        <div class="data-card">
          <div class="card-head"><h3>Boys Lacrosse — Top {{ boys_lax.teams | length }} Teams</h3><div class="date-line">Boys Lacrosse · {{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>School</th><th>County</th><th>Record</th><th>Score</th></tr></thead>
            <tbody>
              {% for team in boys_lax.teams %}
              <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong></td><td>{{ team.county }}</td><td>{{ team.record }}</td><td>{{ team.score }}</td></tr>
              {% endfor %}
            </tbody>
          </table></div>
        </div>

        <!-- Boys Lax Athletes -->
        <div class="data-card">
          <div class="card-head"><h3>Boys Lacrosse — Top {{ boys_lax.athletes | length }} Players</h3><div class="date-line">Boys Lacrosse · {{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>Player</th><th>School</th><th>Sport</th><th>Stats</th><th>Score</th></tr></thead>
            <tbody>
              {% for a in boys_lax.athletes %}
              <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong></td><td>{{ a.school }}</td><td>{{ a.sport }}</td><td>{{ a.stats }}</td><td>{{ a.score }}</td></tr>
              {% endfor %}
            </tbody>
          </table></div>
        </div>
        {% endif %}
      </div>

      <!-- GIRLS RIGHT -->
      <div class="stack">
        <div class="eyebrow" style="margin-bottom:6px;">High School Girls</div>

        {% if girls_softball %}
        <!-- Softball Teams -->
        <div class="data-card">
          <div class="card-head"><h3>Softball — Top {{ girls_softball.teams | length }} Teams</h3><div class="date-line">Softball · {{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>School</th><th>County</th><th>Record</th><th>Score</th></tr></thead>
            <tbody>
              {% for team in girls_softball.teams %}
              <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong></td><td>{{ team.county }}</td><td>{{ team.record }}</td><td>{{ team.score }}</td></tr>
              {% endfor %}
            </tbody>
          </table></div>
        </div>

        <!-- Softball Athletes -->
        <div class="data-card">
          <div class="card-head"><h3>Softball — Top {{ girls_softball.athletes | length }} Players</h3><div class="date-line">Softball · {{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>Player</th><th>School</th><th>Sport</th><th>Commit</th><th>Stats</th><th>Score</th></tr></thead>
            <tbody>
              {% for a in girls_softball.athletes %}
              <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong></td><td>{{ a.school }}</td><td>{{ a.sport }}</td><td>{{ a.commit or "—" }}</td><td>{{ a.stats }}</td><td>{{ a.score }}</td></tr>
              {% endfor %}
            </tbody>
          </table></div>
        </div>
        {% endif %}

        {% if girls_lax %}
        <!-- Girls Lax Teams -->
        <div class="data-card">
          <div class="card-head"><h3>Girls Lacrosse — Top {{ girls_lax.teams | length }} Teams</h3><div class="date-line">Girls Lacrosse · {{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>School</th><th>County</th><th>Record</th><th>Score</th></tr></thead>
            <tbody>
              {% for team in girls_lax.teams %}
              <tr><td class="rank">{{ team.rank }}</td><td><strong>{{ team.team }}</strong></td><td>{{ team.county }}</td><td>{{ team.record }}</td><td>{{ team.score }}</td></tr>
              {% endfor %}
            </tbody>
          </table></div>
        </div>

        <!-- Girls Lax Athletes -->
        <div class="data-card">
          <div class="card-head"><h3>Girls Lacrosse — Top {{ girls_lax.athletes | length }} Players</h3><div class="date-line">Girls Lacrosse · {{ publication.publish_date | displayDate }}</div></div>
          <div class="table-wrap"><table>
            <thead><tr><th>#</th><th>Player</th><th>School</th><th>Sport</th><th>Stats</th><th>Score</th></tr></thead>
            <tbody>
              {% for a in girls_lax.athletes %}
              <tr><td class="rank">{{ a.rank }}</td><td><strong>{{ a.athlete }}</strong></td><td>{{ a.school }}</td><td>{{ a.sport }}</td><td>{{ a.stats }}</td><td>{{ a.score }}</td></tr>
              {% endfor %}
            </tbody>
          </table></div>
        </div>
        {% endif %}
      </div>

    </div><!-- end hs two-col -->

    <!-- HISTORICAL WIN % + NIL — full width -->
    <div class="two-col" style="margin-bottom:24px;">
      <div class="data-card">
        <div class="card-head"><h3>Historical Win %</h3><div class="date-line">All Sports · {{ publication.publish_date | displayDate }}</div></div>
        <div class="table-wrap"><table>
          <thead><tr><th>#</th><th>Program</th><th>Level</th><th>Sport</th><th>Gender</th><th>Win%</th></tr></thead>
          <tbody>
            {% for prog in publication.historical_winpct | take(20) %}
            <tr><td class="rank">{{ loop.index }}</td><td><strong>{{ prog.school }}</strong></td><td>{{ prog.level }}</td><td>{{ prog.sport }}</td><td>{{ prog.gender }}</td><td>{{ prog.win_pct }}%</td></tr>
            {% endfor %}
          </tbody>
        </table></div>
      </div>

      <div class="data-card">
        <div class="card-head"><h3>NIL Tracking</h3><div class="date-line">HS + College · {{ publication.publish_date | displayDate }}</div></div>
        <div class="table-wrap"><table>
          <thead><tr><th>Athlete</th><th>School</th><th>Sport</th><th>Commit / Deal</th></tr></thead>
          <tbody>
            {% if publication.nil_tracking.length %}
              {% for nil in publication.nil_tracking %}
              <tr><td><strong>{{ nil.player }}</strong></td><td>{{ nil.school }}</td><td>{{ nil.sport }}</td><td>{{ nil.commit or "Tracking" }}</td></tr>
              {% endfor %}
            {% else %}
            <tr><td colspan="4" class="empty">NIL data building. Submit tips to yokals@yokalsports.com</td></tr>
            {% endif %}
          </tbody>
        </table></div>
      </div>
    </div>

    {% else %}
    <div class="archive-note">Data will appear here after the first approved publication.</div>
    {% endif %}

  </div>
</section>
" " 
